generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id               BigInt       @id @default(autoincrement())
  email            String
  packageType      String
  guestNameService Boolean      @default(false)
  status           String       @default("draft")
  totalAmount      Int
  sepayRef         String?      @unique
  editToken        String       @unique @default(cuid())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  invitations      Invitation[]
  payment          Payment?
}

model Invitation {
  id           BigInt   @id @default(autoincrement())
  orderId      BigInt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  templateSlug String
  slug         String   @unique
  label        String?
  data         Json
  status       String   @default("demo")
  createdAt    DateTime @default(now())
  wishes       Wish[]
}

model Payment {
  id        BigInt    @id @default(autoincrement())
  orderId   BigInt    @unique
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Int
  status    String    @default("pending")
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}

model Wish {
  id           BigInt     @id @default(autoincrement())
  invitationId BigInt
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  name         String
  message      String
  attend       String
  createdAt    DateTime   @default(now())
}
